{
  "name": "selenium-visual-recorder",
  "version": "1.0.0",
  "description": "Visual test recorder with Selenium and Cucumber",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "concurrently \"tsc --watch\" \"electron . --inspect\"",
    "test": "cucumber-js --config cucumber.json",
    "run-recorded": "npm run test"
  },
  "keywords": [
    "selenium",
    "cucumber",
    "test-automation",
    "electron"
  ],
  "author": "Kevin Huamani",
  "license": "MIT",
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@types/cucumber": "^6.0.1",
    "@types/node": "^20.0.0",
    "@types/selenium-webdriver": "^4.1.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "selenium-webdriver": "^4.18.1"
  }
}
